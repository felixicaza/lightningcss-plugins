{
  "name": "lightningcss-plugins",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "lightningcss",
    "lightningcss-plugin",
    "css",
    "plugin"
  ],
  "license": "MIT",
  "author": "Felix Icaza <fx.joliett17@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "coverage": "vitest run --coverage",
    "dev": "pnpm -r dev",
    "lint": "eslint --cache --fix .",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm build",
    "release": "bumpp -r && pnpm -r publish",
    "test": "vitest",
    "test:update": "vitest --update",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "pnpm lint"
  },
  "devDependencies": {
    "@eslint/js": "catalog:lint",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:testing",
    "bumpp": "catalog:releasing",
    "eslint": "catalog:lint",
    "eslint-plugin-jsonc": "catalog:lint",
    "eslint-plugin-package-json": "catalog:lint",
    "eslint-plugin-yml": "catalog:lint",
    "globals": "catalog:lint",
    "jiti": "catalog:lint",
    "lightningcss": "catalog:peer",
    "nano-staged": "catalog:lint",
    "neostandard": "catalog:lint",
    "simple-git-hooks": "catalog:lint",
    "tsup": "catalog:build",
    "tsx": "catalog:dev",
    "typescript": "catalog:",
    "vitest": "catalog:testing"
  }
}
